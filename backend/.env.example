SECRET_KEY=django-insecure-your-secret-key-change-in-production
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1,devgirlzz.com.uz,www.devgirlzz.com.uz

# Database settings (SQLite for development, PostgreSQL for production)
DATABASE_URL=sqlite:///db.sqlite3

# Email Configuration (REQUIRED for email verification to work!)
# Gmail SMTP (recommended for development)
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-16-character-app-password
DEFAULT_FROM_EMAIL=your-email@gmail.com

# Google AI API Key (for Gemini features)
GOOGLE_AI_API_KEY=your-google-ai-api-key

# CORS settings
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,https://devgirlzz.com.uz,https://www.devgirlzz.com.uz

# OpenAI API Key (optional)
OPENAI_API_KEY=your-openai-api-key

# Frontend (Vite) — set these when building (Render/Vercel). Must match your Django API.
VITE_API_BASE_URL=http://localhost:8000/api/
# Optional: only if admin redirect should go somewhere other than API origin
# VITE_DJANGO_ORIGIN=https://your-api.onrender.com
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=

# Production: same host as Gunicorn + /api/ (see backend Render service URL)
# VITE_API_BASE_URL=https://dev-diva-quest-backend.onrender.com/api/

# Backend (Django on Render): set FRONTEND_URL to your SPA URL so verify-email links work.
# FRONTEND_URL=https://devgirlzz.onrender.com
